# ===== 模型提供商 =====
# 设了 DEEPSEEK_API_KEY 就默认走 DeepSeek；也可用 PERSONA16_PROVIDER=deepseek|anthropic 显式指定
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# 用 Anthropic 时填这个
# ANTHROPIC_API_KEY=

# ===== 可选：覆盖默认模型 =====
# deepseek 默认三个角色都用 deepseek-chat；anthropic 默认 agent=claude-sonnet-5 / director=claude-haiku-4-5
# PERSONA16_AGENT_MODEL=deepseek-chat
# PERSONA16_DIRECTOR_MODEL=deepseek-chat
# PERSONA16_JUDGE_MODEL=deepseek-chat

# ===== 可选：切换 Agent 发言执行层 =====
# DeepSeek 下 pi（默认）使用 @persona16/runtime-pi；需要回滚时设为 legacy。Anthropic 暂默认 legacy。
# 导演/评审结构化 JSON 暂仍走 legacy adapter。
# PERSONA16_RUNTIME=legacy

# ===== 可选：引擎 trace 落盘路径 =====
# PERSONA16_TRACE_FILE=traces/engine.jsonl

# ===== Phase 4：服务端状态 =====
# 生产环境必须使用 PostgreSQL；本地未设置时 Web 会使用进程内临时 Store。
# DATABASE_URL=postgresql://persona16:persona16@localhost:5432/persona16
# PERSONA16_SESSION_SECRET=replace-with-at-least-32-random-characters
# 每次部署设置为 commit SHA 或构建号，用于按版本切分运行指标。
# PERSONA16_BUILD_VERSION=development
# 仅允许单机临时部署显式启用；多实例不要使用。
# PERSONA16_ALLOW_MEMORY_STORE=0
# 仅当部署平台会覆盖/清洗 x-forwarded-for 时启用。
# PERSONA16_TRUST_PROXY=1
